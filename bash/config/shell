# vim: ft=bash

# enable vi mode
# set -o vi

# enable **/* wildards
# shopt -s globstar

# cd
export CDPATH=".:~:~/Dev:~/Dev/Personal:~/.dotfiles"
shopt -s cdspell # fix small typos
complete -d cd

# default programs
export BROWSER=google-chrome-stable
# export EDITOR="nvim -u NONE"
export EDITOR="nvim"

# If we're inside WezTerm, set TERM to wezterm if terminfo is available
if [[ "$WEZTERM_PANE" ]]; then
  if infocmp wezterm >/dev/null 2>&1; then
    export TERM=wezterm
  else
    export TERM=xterm-256color
  fi
fi

# history
export HISTCONTROL=ignoredups:erasedups
export HISTSIZE=100000
export HISTFILESIZE=100000
shopt -s histappend

# config tools
export LESS=-FRSX
# export MANPAGER="/bin/sh -c \"col -b | nvim -c 'set ft=man ts=8 nomod nolist nonu noma' -\""
export MANPAGER="nvim +Man!"
# If the last character of the alias value is a blank, then the next command word following the alias is also checked for alias expansion.
alias sudo='sudo '

# aliases
# -A - show hidden files except . and ..
# -F - append file type indicator
# -G - colorize output
alias ls='ls -FG'
alias lsa='ls -AFG'

alias ..='cd ..'
alias ...='cd ../..'
alias ,,='cd ..'

alias x="exit"

# Set wezterm tab title to current directory name
__set_tab_title() {
  local dir="${PWD##*/}"
  [[ "$PWD" == "$HOME" ]] && dir='$HOME'
  printf "\033]1;%s\007" "$dir"
}
PROMPT_COMMAND="__set_tab_title${PROMPT_COMMAND:+;$PROMPT_COMMAND}"

alias g="fg"

# make a new dir and cd to it
mkcd() {
  mkdir -p $* && cd $*
}

# cd one level up and rm previous dir
rmup() {
  pwd=$(pwd)
  cd ..
  read -p "Remove ${pwd} ? " choice
  case "$choice" in
  y | Y)
    echo "removing ${pwd}"
    rm -rf "$pwd"
    ;;
  esac
}
