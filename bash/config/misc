# vim: ft=bash

# git-style diff
gdiff() {
  diff -u $@ | colordiff
}

# generate random integet from 1 to arg
randint() {
  python3 -c "import random; print(random.randint(1, $1))"
}

# start HTTP server in current dir
alias serve="python3 -m http.server"

# duh
alias killeslint="ps aux | grep eslint | grep -v grep | awk '{print $2}' | xargs kill"

vimviki2markdown() {
  pandoc -f vimwiki "$1" -t gfm --wrap=none | pbcopy
}

# always run opencode with --port flag
alias opencode="opencode --port"

# neovim 0.12
alias nvim-0.12="NVIM_APPNAME=nvim-0.12 bob run v0.12.1"
# neovim nightly
alias nvim-nightly="NVIM_APPNAME=nvim-nightly bob run nightly"
